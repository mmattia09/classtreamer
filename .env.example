# Database connection (Prisma)
DB_HOST="postgres"
DB_PORT="5432"
DB_NAME="classtreamer"
DB_USER="classtreamer"
DB_PASSWORD="classtreamer"
# Required by Prisma CLI (keep it aligned with DB_*).
DB_URL="postgresql://classtreamer:classtreamer@postgres:5432/classtreamer?schema=public"

# Cache
REDIS_URL="redis://redis:6379"

# Admin access
ADMIN_PASSWORD="cambia-questa-password"
SESSION_SECRET="cambia-questa-stringa-lunga"
SESSION_COOKIE_SECURE="false"

# App URLs
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_PATH="/socket.io"
PORT="3000"
