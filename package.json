{
  "name": "classtreamer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun server.js",
    "dev:start": "bun ./scripts/devstart.mjs",
    "build": "bun run prisma:generate && next build",
    "start": "NODE_ENV=production bun server.js",
    "lint": "next lint",
    "prisma:generate": "bun ./scripts/with-derived-env.mjs bunx prisma generate",
    "prisma:migrate": "bun ./scripts/with-derived-env.mjs bunx prisma migrate deploy",
    "prisma:push": "bun ./scripts/with-derived-env.mjs bunx prisma db push",
    "prisma:seed": "bun ./scripts/with-derived-env.mjs bunx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@radix-ui/react-slot": "^1.1.2",
    "bcryptjs": "^3.0.2",
    "chart.js": "^4.4.8",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "ioredis": "^5.5.0",
    "lucide-react": "^0.483.0",
    "next": "^15.2.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
